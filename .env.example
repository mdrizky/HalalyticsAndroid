# .env file

# MUI API Configuration
MUI_API_URL=https://api.halalmui.org/v1
MUI_API_KEY=your_mui_api_key_here
MUI_API_TIMEOUT=30

# JAKIM API Configuration (Malaysia)
JAKIM_API_URL=https://www.islam.gov.my/api
JAKIM_API_KEY=your_jakim_api_key_here

# Scraping Configuration
HALAL_SCRAPING_ENABLED=true
SCRAPING_USER_AGENT=HalalyticsBot/1.0
SCRAPING_DELAY=2
SCRAPING_MAX_RETRIES=3

# Cache Configuration
HALAL_CACHE_DURATION=259200  # 30 days
HALAL_API_CACHE_DURATION=300  # 5 minutes
HALAL_STATS_CACHE_DURATION=3600  # 1 hour

# Background Jobs
HALAL_RECHECK_ENABLED=true
HALAL_RECHECK_INTERVAL="0 2 * * *"  # Daily at 2 AM
HALAL_BATCH_SIZE=100
